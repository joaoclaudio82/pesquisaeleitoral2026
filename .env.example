# Copie para .env e ajuste os valores
# cp .env.example .env

FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=troque-por-uma-chave-segura-aqui

# PostgreSQL — opção 1: URL completa (sobrescreve POSTGRES_*)
# DATABASE_URL=postgresql://eleitoral:eleitoral@localhost:5432/eleitoral2026

# PostgreSQL — opção 2: variáveis individuais (padrão abaixo)
POSTGRES_USER=eleitoral
POSTGRES_PASSWORD=eleitoral
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=eleitoral2026

# Intervalo de simulação de coleta em segundos (padrão: 120)
UPDATE_INTERVAL=120

# Usuário administrador inicial (criado se o banco não tiver usuários)
ADMIN_EMAIL=admin@eleitoral.local
ADMIN_PASSWORD=admin123
ADMIN_NOME=Administrador
